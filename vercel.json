{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.gazeoff.com" }],
      "destination": "https://gazeoff.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/website/" },
    { "source": "/:path*", "destination": "/website/:path*" }
  ]
}
